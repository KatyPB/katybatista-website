---
import "../styles/global.css";

const {
  title = "Katy Batista | Songwriter · Lyricist · Author"
} = Astro.props;
---

<!DOCTYPE html>
<html lang="pt">

<head>

  <meta charset="UTF-8" />

  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <title>{title}</title>

  <meta
    name="description"
    content="Official website of Katy Batista. Original songs, lyrics and musical works."
  />

  <link rel="preconnect" href="https://fonts.googleapis.com" />

  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

  <link
    href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@300;400;500;600&family=Inter:wght@300;400;500&display=swap"
    rel="stylesheet"
  />

</head>

<body>

  <slot />

</body>

</html>